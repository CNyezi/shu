{
  "id": "com.shu.hosts-editor",
  "name": "Hosts 编辑器",
  "version": "0.1.0",
  "description": "编辑 /etc/hosts，保存时通过系统管理员授权写入",
  "icon": "icon.svg",
  "features": [
    {
      "code": "hosts",
      "type": "ui",
      "entry": "index.html",
      "triggers": [{ "kind": "keyword", "value": "hosts" }]
    }
  ],
  "permissions": ["hosts.read", "hosts.write"]
}
